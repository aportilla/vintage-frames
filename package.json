{
  "name": "vintage-frames",
  "version": "0.1.0",
  "description": "Lit web components that emulate the look and feel of classic Mac OS System 7",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css",
    "**/register-embedded-font.*",
    "**/chikarego-font.*",
    "**/finders-keepers-font.*"
  ],
  "main": "./dist/vintage-frames.js",
  "module": "./dist/vintage-frames.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vintage-frames.js"
    },
    "./vintage.css": "./src/styles/vintage.css"
  },
  "files": [
    "dist",
    "src",
    "SPEC.md"
  ],
  "keywords": [
    "lit",
    "web-components",
    "system7",
    "mac-os-classic",
    "retro",
    "ui-kit"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}

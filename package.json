{
  "name": "vintage-frames",
  "version": "0.1.0",
  "description": "Lit web components that emulate the look and feel of classic Mac OS System 7",
  "type": "module",
  "license": "MIT",
  "sideEffects": true,
  "main": "./dist/vintage-frames.js",
  "module": "./dist/vintage-frames.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vintage-frames.js"
    },
    "./vintage.css": "./src/styles/vintage.css"
  },
  "files": [
    "dist",
    "src",
    "SPEC.md"
  ],
  "keywords": [
    "lit",
    "web-components",
    "system7",
    "mac-os-classic",
    "retro",
    "ui-kit"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "extract:buttons": "python3 scripts/extract-button-pixels.py",
    "probe:buttons": "python3 scripts/probe-button-colors.py",
    "verify:buttons": "tsc src/pixel-frame.ts --outDir scripts/.tmp --target es2022 --module esnext --moduleResolution bundler --skipLibCheck && node scripts/emit-clips.mjs && python3 scripts/verify-button-clips.py",
    "shot:buttons": "npx playwright screenshot --wait-for-timeout=2000 http://localhost:5173/pixel-test.html shots/buttons.png",
    "shot:verify": "python3 scripts/verify-button-screenshot.py shots/buttons.png"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
